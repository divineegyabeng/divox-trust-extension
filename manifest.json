{
  "manifest_version": 3,
  "name": "DivoX Trust — Scam Detector",
  "version": "1.0.0",
  "description": "Right-click any link to instantly check if it is a scam with DivoX Trust AI.",
  "permissions": ["contextMenus", "storage", "activeTab"],
  "host_permissions": ["https://divoxtrust.vercel.app/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
